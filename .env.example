# .env.example — скопируйте в .env и заполните значения

# === Agent Security ===
AGENT_API_KEY=your-agent-secret-key-here
QDRANT_API_KEY=your-qdrant-secret-key-here
DEFAULT_ROLE=editor

# === LLM Configuration ===
LLM_MODEL_NAME=cartoon-planner-v2
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# === Workspace ===
WORKSPACE_HOST_PATH=/home/roman/Документы/Unreal Projects/мульт

# === Observability ===
LOG_LEVEL=INFO
TRACE_SAMPLING_RATE=1.0
SLACK_WEBHOOK=https://hooks.slack.com/services/XXX

# === Asset Pipeline ===
ASSET_CACHE_MAX_SIZE_GB=10
ALLOWED_DOMAINS=assets.cartoon.local,cdn.trusted.com